# Base URL for NTULearn (Blackboard Learn instance)
# Default is fine — only change if you're using a different instance
NTULEARN_BASE_URL=https://ntulearn.ntu.edu.sg

# Your BbRouter session cookie value.
# How to get it:
#   1. Open https://ntulearn.ntu.edu.sg in Chrome/Firefox and log in
#   2. Open DevTools → Application → Cookies → https://ntulearn.ntu.edu.sg
#   3. Find the cookie named "BbRouter"
#   4. Copy the Value field (starts with "expires:" or similar)
#   5. Paste it here — either with or without the "BbRouter=" prefix is fine
#
# The cookie typically lasts for the duration of your browser session.
# If you see "BbRouter cookie has expired" errors, repeat the steps above.
NTULEARN_COOKIE=
# Directory where downloaded files are saved (relative to where you run the server)
NTULEARN_DOWNLOAD_DIR=./downloads
