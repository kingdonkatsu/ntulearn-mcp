# All values are optional. The defaults work for most users.
# Set them only to override the defaults — see README for details.

# Manual fallback cookie. By default the server reads BbRouter from your
# logged-in browser (Edge → Chrome → Firefox → Brave); this env var is only
# consulted if that auto-read fails. Use it when auto-read can't work on your
# platform — most commonly Windows + Chrome/Edge with App-Bound Encryption.
# A fresh browser read always wins over this value, so updating it doesn't
# disable auto-refresh; it just provides a safety net for environments where
# browser-cookie3 returns nothing.
#
# How to get it manually:
#   1. Open https://ntulearn.ntu.edu.sg in your browser, log in
#   2. DevTools (F12) → Application → Cookies → ntulearn.ntu.edu.sg
#   3. Copy the Value of the BbRouter cookie (starts with "expires:")
#NTULEARN_COOKIE=

# Base URL for your Blackboard Learn instance.
#NTULEARN_BASE_URL=https://ntulearn.ntu.edu.sg

# Where download_file saves files (relative to where the server runs).
#NTULEARN_DOWNLOAD_DIR=./downloads
